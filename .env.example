# AD360 Identity Security Analytics — Environment Configuration
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# AD360 Connection Settings
# ---------------------------------------------------------------------------
# Base URL of your AD360 instance (including port)
AD360_BASE_URL=https://your-ad360-instance:8082

# API authentication token for AD360 REST API
AD360_AUTH_TOKEN=your_api_token_here

# Set to "false" to use live AD360 data instead of mock data
USE_MOCK_DATA=true

# ---------------------------------------------------------------------------
# Notification Settings
# ---------------------------------------------------------------------------
ALERT_EMAIL=security-team@yourcompany.com

# ---------------------------------------------------------------------------
# Organisation Settings
# ---------------------------------------------------------------------------
ORG_NAME=Acme Corporation
ENVIRONMENT=Production
